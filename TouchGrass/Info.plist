<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>

	<!-- Disable Firebase method swizzling — APNs token and FCM delegate
	     are forwarded manually in AppDelegate / NotificationManager. -->
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>

	<!-- Privacy usage descriptions -->
	<key>NSCameraUsageDescription</key>
	<string>TouchGrass uses your camera to take dual-camera story photos to share with friends.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>TouchGrass uses your location to show you on the map and help you find nearby friends.</string>
	<key>NSMotionUsageDescription</key>
	<string>This app uses motion data to track your steps.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>TouchGrass reads your step count from Apple Health to include Apple Watch steps in your daily total and leaderboard score.</string>

	<!-- Scene manifest (SwiftUI @main App — scene lifecycle managed by SwiftUI) -->
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>

	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Custom fonts (register both common download names) -->
	<key>UIAppFonts</key>
	<array>
		<string>Billabong.ttf</string>
		<string>Billabong-Regular.ttf</string>
	</array>

	<!-- Launch screen -->
	<key>UILaunchScreen</key>
	<dict/>

	<!-- Supported orientations — iPhone -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>

	<!-- Supported orientations — iPad -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
